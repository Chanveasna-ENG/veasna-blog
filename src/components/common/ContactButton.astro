---
interface Props {
  href: string;
  icon?: string; // Expects a raw SVG string if provided
  text: string;
}

const { href, icon, text } = Astro.props;
---

<a 
  href={href}
  class="inline-flex items-center justify-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-md text-darkBg bg-gold hover:bg-yellow-500 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-darkBg focus:ring-gold transition-all duration-200 gap-2"
>
  {icon && (
    <span class="flex-shrink-0 w-5 h-5 flex items-center justify-center">
      <Fragment set:html={icon} />
    </span>
  )}
  <span>{text}</span>
</a>