---
import type { CollectionEntry } from 'astro:content';
import { formatDateICT } from '../../utils/date';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="bg-lightDark/10 border border-lightDark rounded-xl overflow-hidden hover:border-gold transition duration-300 group h-[280px] flex flex-col">
  <div class="p-6 flex flex-col h-full relative">
    <!-- Category Badge -->
    <div class="absolute top-6 right-6">
       <span class="text-[10px] uppercase tracking-widest text-gold border border-gold px-2 py-1 rounded-md">
         {post.data.category}
       </span>
    </div>

    <h2 class="text-2xl font-serif font-bold text-offWhite group-hover:text-gold transition line-clamp-2 pr-12">
      <a href={`/posts/${post.slug}`}>
        {post.data.title}
      </a>
    </h2>
    
    <div class="text-xs text-gray-500 mt-2 font-sans flex items-center gap-2">
      <time datetime={post.data.createdAt.toISOString()}>
        {formatDateICT(post.data.createdAt)}
      </time>
    </div>

    <p class="text-gray-400 mt-4 text-sm font-sans line-clamp-3 flex-grow">
      {post.data.description}
    </p>

    <div class="mt-auto pt-4 flex items-center text-sm font-bold text-gold uppercase tracking-wider font-sans">
      Read Article 
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </div>
  </div>
</article>