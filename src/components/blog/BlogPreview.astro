---
import type { CollectionEntry } from 'astro:content';
import { formatDateICT } from '../../utils/date';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

// Enforce fallback logic for dates locally to maintain a pure template
const targetDate = post.data.lastModifiedAt || post.data.createdAt;
---

<article class="flex flex-col h-full p-6 bg-darkBg border border-gray-700 rounded-lg shadow-sm hover:border-gold transition-colors duration-200 group">
  
  {/* Title & Description (Clickable Area) */}
  <a href={`/posts/${post.slug}`} class="block flex-grow mb-4 focus:outline-none focus:ring-2 focus:ring-gold rounded-sm">
    <h2 class="text-2xl font-alice text-gold group-hover:text-yellow-500 transition-colors duration-200 mb-2">
      {post.data.title}
    </h2>
    <p class="text-gray-300 line-clamp-3">
      {post.data.description}
    </p>
  </a>

  {/* Meta Information Container */}
  <div class="flex flex-col space-y-3 mt-auto pt-4 border-t border-gray-800">
    
    {/* Author & Date Row */}
    <div class="flex flex-wrap items-center justify-between text-xs text-gray-400 gap-2">
      <span>
        Author: <span class="text-offWhite font-medium">{post.data.author}</span>
      </span>
      <time datetime={targetDate.toISOString()}>
        Last Modified: <span class="text-offWhite">{formatDateICT(targetDate)}</span>
      </time>
    </div>

    {/* Category Badge & Tags Row */}
    <div class="flex flex-wrap items-center gap-2 mt-1">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-800 text-gold border border-gray-700 uppercase tracking-wider">
        {post.data.category}
      </span>
      
      <div class="flex flex-wrap gap-1">
        {post.data.tags.map((tag) => (
          <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-700 text-gray-300">
            #{tag}
          </span>
        ))}
      </div>
    </div>
    
  </div>
</article>