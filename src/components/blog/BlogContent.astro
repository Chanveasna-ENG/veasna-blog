---
// Implements the visual renderer for the markdown body per TRD 4.2 I.
// Expects the rendered Astro <Content /> to be passed as children via <slot />.
---

<article 
  class="
    prose prose-lg prose-invert max-w-none w-full
    prose-headings:font-alice prose-headings:text-gold 
    prose-a:text-gold prose-a:no-underline hover:prose-a:text-yellow-500 hover:prose-a:underline
    prose-img:rounded-xl prose-img:border prose-img:border-gray-700 prose-img:shadow-md
    prose-code:text-gold prose-code:bg-gray-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:hidden prose-code:after:hidden
    prose-pre:bg-gray-900 prose-pre:border prose-pre:border-gray-700
    prose-blockquote:border-l-gold prose-blockquote:bg-gray-800/50 prose-blockquote:px-6 prose-blockquote:py-2 prose-blockquote:not-italic prose-blockquote:rounded-r-lg
  "
>
  <slot />
</article>