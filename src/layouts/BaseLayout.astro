---
import Navigation from '../components/common/Navigation.astro';
import Footer from '../components/common/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const { 
  title, 
  description = "Portfolio of ENG Chanveasna, specializing in AI, Workflow Automation, and Web Design.",
  activePage 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts: Alice (Serif) & Inter (Sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alice&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body class="bg-darkBg text-offWhite selection:bg-gold selection:text-darkBg flex flex-col min-h-screen font-serif">
    <Navigation activePage={activePage} />
    
    <main class="flex-grow">
        <slot />
    </main>

    <Footer />
</body>
</html>