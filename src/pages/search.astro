---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchFeed from '../components/interactive/SearchFeed';
import ProfileCard from '../components/common/ProfileCard.astro';
---

<BaseLayout title="Search Results | Veasna." description="Search through all the articles, projects, and learning resources.">
  
  <div class="w-full grid grid-cols-1 lg:grid-cols-[7fr_3fr] gap-10 mt-8 mb-16 px-4 md:px-0">
    
    <div class="flex flex-col space-y-10 min-w-0">
      <SearchFeed client:only="react" />
    </div>

    <aside class="flex flex-col space-y-8">
      <div class="sticky top-24">
        <ProfileCard />
      </div>
    </aside>

  </div>
</BaseLayout>
